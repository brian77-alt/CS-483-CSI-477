@page
@model PlannerModel
@{
    ViewData["Title"] = "Course Planner";
}

<div class="fade-in-up">
    <form id="antiForgeryForm" method="post">
        @Html.AntiForgeryToken()
    </form>

    <!-- Header -->
    <div class="welcome-banner mb-4">
        <div class="gold-tag">
            <i class="bi bi-calendar3" aria-hidden="true"></i>
            Course Planner
        </div>
        <h1 class="mb-1">@Model.StudentName.Split(' ')[0]'s Plan</h1>
        <p class="mb-0">@Model.Major</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        var alertClass = Model.StatusType switch
        {
            "success" => "alert-success",
            "error" => "alert-danger",
            "warning" => "alert-warning",
            _ => "alert-info"
        };
        var alertIcon = Model.StatusType switch
        {
            "success" => "bi-check-circle-fill",
            "error" => "bi-x-circle-fill",
            "warning" => "bi-exclamation-triangle-fill",
            _ => "bi-info-circle-fill"
        };
        <div class="alert @alertClass alert-dismissible fade show mb-4" role="alert">
            <i class="bi @alertIcon me-2" aria-hidden="true"></i>
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- 4-Year Grid -->
    <div class="section-header mb-3">
        <h6>
            <span class="section-icon"><i class="bi bi-calendar3" aria-hidden="true"></i></span>
            4-Year Degree Plan
        </h6>
        <span style="font-size:0.78rem; color:var(--slate-500);">
            <i class="bi bi-info-circle me-1"></i>
            Courses can only be dropped into semesters when they are offered
        </span>
    </div>

    <div class="row g-3 mb-4">
        @for (int i = 0; i < Model.Semesters.Count; i++)
        {
            var semester = Model.Semesters[i];
            var yearLabel = (i / 2) + 1;
            var isFall = semester.Term == "Fall";

            <div class="col-lg-6 fade-in-up fade-in-up-delay-@((i % 4) + 1)">
                <div class="card h-100 planner-semester-card"
                     style="border-top: 3px solid @(isFall ? "var(--navy)" : "var(--gold)") !important;">
                    <div class="card-header d-flex justify-content-between align-items-center @(isFall ? "" : "gold")">
                        <span>
                            <i class="bi bi-@(isFall ? "wind" : "brightness-high") me-2" aria-hidden="true"></i>
                            Year @yearLabel · @semester.Term @semester.Year
                        </span>
                        <span class="badge" style="background:rgba(255,255,255,0.2); font-size:0.7rem;">
                            @semester.TotalCredits cr
                        </span>
                    </div>

                    <div class="card-body p-0 planner-drop-zone"
                         data-term="@semester.Term"
                         data-year="@semester.Year">
                        @if (semester.Courses.Any())
                        {
                            <table class="table mb-0" aria-label="@semester.Term @semester.Year courses">
                                <tbody>
                                    @foreach (var course in semester.Courses)
                                    {
                                        <tr style="@(course.IsCompleted ? "background:var(--slate-50);" : "")">
                                            <td style="padding:0.75rem 1.25rem; width:1%;">
                                                @if (course.IsCompleted)
                                                {
                                                    <span style="color:var(--success); font-size:1rem;" aria-label="Completed">
                                                        <i class="bi bi-check-circle-fill" aria-hidden="true"></i>
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span style="color:var(--slate-300); font-size:1rem;" aria-hidden="true">
                                                        <i class="bi bi-circle"></i>
                                                    </span>
                                                }
                                            </td>

                                            <td style="padding:0.75rem 0.5rem 0.75rem 0;">
                                                <div style="font-weight:700; font-size:0.8rem; color:var(--navy); letter-spacing:0.02em;">
                                                    @course.CourseCode
                                                </div>
                                                <div style="font-size:0.78rem; color:var(--slate-500); line-height:1.3;">
                                                    @course.CourseName
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(course.TermsOffered))
                                                {
                                                    <div style="margin-top:0.2rem;">
                                                        <span style="font-size:0.68rem; background:var(--slate-100); color:var(--slate-500); padding:0.1rem 0.4rem; border-radius:4px;">
                                                            @course.TermsOffered
                                                        </span>
                                                    </div>
                                                }
                                            </td>

                                            <td style="padding:0.75rem 0.5rem; text-align:right; white-space:nowrap;">
                                                <span style="font-size:0.75rem; color:var(--slate-400);">
                                                    @course.CreditHours cr
                                                </span>
                                            </td>

                                            <td style="padding:0.75rem 1rem 0.75rem 0; text-align:right; white-space:nowrap;">
                                                @if (!course.IsCompleted && course.PlannedCourseID > 0)
                                                {
                                                    <button type="button"
                                                            class="btn btn-sm btn-outline-danger"
                                                            onclick="removePlannedCourse(@course.PlannedCourseID)"
                                                            aria-label="Remove @course.CourseCode">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="text-center py-4 planner-empty-drop" style="color:var(--slate-400); min-height:150px;">
                                <i class="bi bi-inbox" style="font-size:1.5rem; display:block; margin-bottom:0.4rem;" aria-hidden="true"></i>
                                <span style="font-size:0.8rem;">Drop courses here</span>
                            </div>
                        }
                    </div>

                    <div style="padding:0.625rem 1.25rem; background:var(--slate-50); border-top:1px solid var(--slate-100); font-size:0.75rem; color:var(--slate-500);">
                        @semester.Courses.Count course(s) · @semester.TotalCredits credit(s)
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Available Courses -->
    <div class="card mb-4 fade-in-up">
        <div class="card-header d-flex align-items-center justify-content-between">
            <span>
                <i class="bi bi-collection me-2" aria-hidden="true"></i>Available Courses
            </span>
            @if (Model.AvailableCourses != null && Model.AvailableCourses.Rows.Count > 0)
            {
                <span class="badge" style="background:rgba(255,255,255,0.2); font-size:0.7rem;">
                    @Model.AvailableCourses.Rows.Count courses
                </span>
            }
        </div>

        <div class="alert alert-warning mb-0" style="border-radius:0; border-left:none; border-right:none; border-top:none; font-size:0.85rem;">
            <i class="bi bi-lightbulb-fill me-2" aria-hidden="true"></i>
            Drag a course and drop it into a semester. Courses can only be placed in semesters when they are offered.
            <span style="margin-left:0.5rem;">
                <span style="background:var(--gold-pale); color:var(--gold); font-size:0.72rem; padding:0.15rem 0.5rem; border-radius:4px; font-weight:600;">Fall</span>
                <span style="background:#e8f4ff; color:#1d4ed8; font-size:0.72rem; padding:0.15rem 0.5rem; border-radius:4px; font-weight:600; margin-left:0.25rem;">Spring</span>
                badges show when a course is offered.
            </span>
        </div>

        <div class="table-responsive">
            <table class="table mb-0" aria-label="Available courses">
                <thead>
                    <tr>
                        <th>Course</th>
                        <th>Name</th>
                        <th>Cr</th>
                        <th>Dept</th>
                        <th>Offered</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.AvailableCourses != null && Model.AvailableCourses.Rows.Count > 0)
                    {
                        @foreach (System.Data.DataRow row in Model.AvailableCourses.Rows)
                        {
                            var termsRaw = row["TypicalTermsOffered"]?.ToString() ?? "";
                            <tr class="planner-draggable-course"
                                draggable="true"
                                data-course-id="@row["CourseID"]"
                                data-terms-offered="@termsRaw">
                                <td>
                                    <span style="font-weight:700; color:var(--navy); font-size:0.85rem;">
                                        @row["CourseCode"]
                                    </span>
                                </td>
                                <td style="font-size:0.875rem; color:var(--slate-700);">@row["CourseName"]</td>
                                <td style="font-size:0.8rem; color:var(--slate-500);">@row["CreditHours"]</td>
                                <td>
                                    <span class="badge-grade" style="background:var(--slate-100); color:var(--slate-600);">
                                        @row["Department"]
                                    </span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(termsRaw))
                                    {
                                        var termList = termsRaw.Split(',').Select(t => t.Trim());
                                        foreach (var t in termList)
                                        {
                                            var bg = t.Equals("Fall", StringComparison.OrdinalIgnoreCase)
                                            ? "background:var(--gold-pale); color:var(--gold);"
                                            : t.Equals("Spring", StringComparison.OrdinalIgnoreCase)
                                            ? "background:#e8f4ff; color:#1d4ed8;"
                                            : "background:var(--slate-100); color:var(--slate-600);";
                                            <span style="@bg font-size:0.68rem; padding:0.15rem 0.5rem; border-radius:4px; font-weight:600; margin-right:2px;">@t</span>
                                        }
                                    }
                                    else
                                    {
                                        <span style="color:var(--slate-300); font-size:0.75rem;">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5" style="color:var(--slate-500);">
                                <i class="bi bi-inbox" style="font-size:2rem; display:block; margin-bottom:0.5rem;" aria-hidden="true"></i>
                                No available courses found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Tips -->
    <div class="card fade-in-up">
        <div class="card-body" style="padding:1.25rem 1.5rem;">
            <div class="section-header" style="margin-bottom:0.75rem; padding-bottom:0.75rem;">
                <h6>
                    <span class="section-icon"><i class="bi bi-lightbulb-fill" aria-hidden="true"></i></span>
                    Planning Tips
                </h6>
            </div>
            <div class="row g-2">
                <div class="col-md-6">
                    <ul class="mb-0" style="font-size:0.875rem; color:var(--slate-700); padding-left:1.25rem; display:flex; flex-direction:column; gap:0.4rem;">
                        <li>Aim for 12–18 credits per semester (15 is typical)</li>
                        <li>Check prerequisites before planning courses</li>
                        <li>Fall-only courses cannot be placed in Spring semesters</li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <ul class="mb-0" style="font-size:0.875rem; color:var(--slate-700); padding-left:1.25rem; display:flex; flex-direction:column; gap:0.4rem;">
                        <li>Balance difficult courses with easier ones each semester</li>
                        <li>Courses marked <i class="bi bi-check-circle-fill text-success"></i> are already completed</li>
                        <li>Term badges show when each course is offered</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .planner-draggable-course {
        cursor: grab;
        transition: background-color 0.2s ease, opacity 0.2s ease;
    }

        .planner-draggable-course:hover {
            background: var(--slate-50);
        }

        .planner-draggable-course.dragging {
            opacity: 0.4;
            cursor: grabbing;
        }

    .planner-drop-zone {
        min-height: 150px;
        position: relative;
        transition: background-color 0.15s ease;
    }

        .planner-drop-zone.drag-over {
            background: #eef6ff;
            outline: 2px dashed var(--navy);
            outline-offset: -6px;
        }

        .planner-drop-zone.drag-reject {
            background: #fff0f0;
            outline: 2px dashed var(--danger, #b91c1c);
            outline-offset: -6px;
        }

    @@keyframes shake {
        0%, 100%

    {
        transform: translateX(0);
    }

    20% {
        transform: translateX(-7px);
    }

    40% {
        transform: translateX(7px);
    }

    60% {
        transform: translateX(-4px);
    }

    80% {
        transform: translateX(4px);
    }

    }

    .planner-drop-zone.shake {
        animation: shake 0.4s ease;
    }

    .drop-error-toast {
        position: absolute;
        bottom: 10px;
        left: 50%;
        transform: translateX(-50%);
        background: #b91c1c;
        color: white;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.35rem 0.9rem;
        border-radius: 6px;
        white-space: nowrap;
        z-index: 20;
        pointer-events: none;
        animation: fadeInUp 0.2s ease;
    }

    @@keyframes fadeInToast {
        from

    {
        opacity: 0;
        transform: translateX(-50%) translateY(6px);
    }

    to {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }

    }
</style>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const draggableCourses = document.querySelectorAll(".planner-draggable-course");
            const dropZones = document.querySelectorAll(".planner-drop-zone");

            let draggedTermsOffered = "";

            draggableCourses.forEach(course => {
                course.addEventListener("dragstart", function (e) {
                    this.classList.add("dragging");
                    e.dataTransfer.setData("courseId", this.dataset.courseId);
                    e.dataTransfer.setData("termsOffered", this.dataset.termsOffered || "");
                    draggedTermsOffered = this.dataset.termsOffered || "";
                    e.dataTransfer.effectAllowed = "move";
                });

                course.addEventListener("dragend", function () {
                    this.classList.remove("dragging");
                    draggedTermsOffered = "";
                    // Clear all zone states
                    dropZones.forEach(z => {
                        z.classList.remove("drag-over", "drag-reject");
                    });
                });
            });

            dropZones.forEach(zone => {
                zone.addEventListener("dragover", function (e) {
                    e.preventDefault();
                    const term = this.dataset.term;
                    const valid = isTermValid(draggedTermsOffered, term);
                    this.classList.toggle("drag-over", valid);
                    this.classList.toggle("drag-reject", !valid);
                    e.dataTransfer.dropEffect = valid ? "move" : "none";
                });

                zone.addEventListener("dragenter", function (e) {
                    e.preventDefault();
                });

                zone.addEventListener("dragleave", function (e) {
                    // Only remove if we actually left the zone (not entering a child)
                    if (!this.contains(e.relatedTarget)) {
                        this.classList.remove("drag-over", "drag-reject");
                    }
                });

                zone.addEventListener("drop", function (e) {
                    e.preventDefault();
                    this.classList.remove("drag-over", "drag-reject");

                    const courseId    = e.dataTransfer.getData("courseId");
                    const termsOffered = e.dataTransfer.getData("termsOffered");
                    const term        = this.dataset.term;
                    const year        = this.dataset.year;

                    if (!isTermValid(termsOffered, term)) {
                        // Shake and show error
                        this.classList.add("shake");
                        this.addEventListener("animationend", () => {
                            this.classList.remove("shake");
                        }, { once: true });

                        const offered = termsOffered
                            ? termsOffered
                            : "specific terms";
                        showDropError(this, `Only offered in: ${offered}`);
                        return;
                    }

                    if (courseId && term && year) {
                        submitAddCourse(courseId, term, year);
                    }
                });
            });
        });

        function isTermValid(termsOffered, targetTerm) {
            // If no term data, allow the drop (server will validate)
            if (!termsOffered || termsOffered.trim() === "") return true;
            const offered = termsOffered.split(",").map(t => t.trim().toLowerCase());
            return offered.includes(targetTerm.toLowerCase());
        }

        function showDropError(zone, message) {
            // Remove any existing toast
            const existing = zone.querySelector(".drop-error-toast");
            if (existing) existing.remove();

            const toast = document.createElement("div");
            toast.className = "drop-error-toast";
            toast.textContent = message;
            zone.appendChild(toast);

            setTimeout(() => {
                if (toast.parentNode) toast.remove();
            }, 2500);
        }

        function getAntiForgeryToken() {
            return document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]').value;
        }

        function submitAddCourse(courseId, term, year) {
            const form = document.createElement("form");
            form.method = "post";
            form.action = "?handler=AddCourse";
            form.innerHTML = `
                <input type="hidden" name="__RequestVerificationToken" value="${getAntiForgeryToken()}" />
                <input type="hidden" name="courseId" value="${courseId}" />
                <input type="hidden" name="term" value="${term}" />
                <input type="hidden" name="year" value="${year}" />
            `;
            document.body.appendChild(form);
            form.submit();
        }

        function removePlannedCourse(plannedCourseId) {
            const form = document.createElement("form");
            form.method = "post";
            form.action = "?handler=RemoveCourse";
            form.innerHTML = `
                <input type="hidden" name="__RequestVerificationToken" value="${getAntiForgeryToken()}" />
                <input type="hidden" name="plannedCourseId" value="${plannedCourseId}" />
            `;
            document.body.appendChild(form);
            form.submit();
        }
    </script>
}
