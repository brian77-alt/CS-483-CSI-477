@page
@model CS_483_CSI_477.Pages.TranscriptModel
@{
    ViewData["Title"] = "Degree Works Transcript";
}

<div class="fade-in-up">

    <!-- Header -->
    <div class="welcome-banner mb-4">
        <div class="gold-tag">
            <i class="bi bi-file-earmark-text-fill" aria-hidden="true"></i>
            Degree Works Transcript
        </div>
        <h1 class="mb-1">Upload Your Transcript</h1>
        <p class="mb-0">Upload your USI Degree Works worksheet so the AI can understand your transfer credits, completed courses, and remaining requirements.</p>
    </div>

    <!-- Status Message -->
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert @(Model.StatusType == "success" ? "alert-success" : "alert-danger") alert-dismissible fade show mb-4"
             role="alert" aria-live="polite">
            <i class="bi bi-@(Model.StatusType == "success" ? "check-circle-fill" : "x-circle-fill") me-2" aria-hidden="true"></i>
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">

        <!-- Upload Card -->
        <div class="col-lg-6">
            <div class="card h-100" style="border-radius:16px;">
                <div class="card-header">
                    <i class="bi bi-cloud-upload me-2" aria-hidden="true"></i>Upload Degree Works PDF
                </div>
                <div class="card-body">
                    <p style="font-size:0.875rem; color:var(--slate-600); margin-bottom:1.25rem;">
                        Export your Degree Works audit as a PDF from the USI portal, then upload it here.
                        The AI will use it to understand your transfer credits, AP credits, and exactly
                        which requirements you have completed.
                    </p>

                    <form method="post" asp-page-handler="Upload" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label" for="transcriptFile" style="font-weight:600; font-size:0.875rem;">
                                Degree Works PDF <span class="text-danger">*</span>
                            </label>
                            <input type="file" name="transcriptFile" id="transcriptFile"
                                   class="form-control" accept=".pdf" required
                                   aria-describedby="transcriptHelp" />
                            <div id="transcriptHelp" class="form-text">
                                Max 50MB · PDF only · Exported from USI Degree Works
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100" id="uploadBtn">
                            <i class="bi bi-cloud-upload me-2" aria-hidden="true"></i>Upload and Parse
                        </button>
                    </form>

                    <div class="mt-3 p-3" style="background:var(--slate-50); border-radius:10px; font-size:0.8rem; color:var(--slate-600);">
                        <strong style="color:var(--navy);">How to export from Degree Works:</strong>
                        <ol class="mb-0 mt-1" style="padding-left:1.25rem;">
                            <li>Log in to myUSI and open Degree Works</li>
                            <li>Click "Create PDF" in the top right corner</li>
                            <li>Save the PDF and upload it here</li>
                        </ol>
                    </div>
                </div>
            </div>
        </div>

        <!-- Current Transcript Status -->
        <div class="col-lg-6">
            <div class="card h-100" style="border-radius:16px;">
                <div class="card-header gold">
                    <i class="bi bi-file-earmark-check me-2" aria-hidden="true"></i>Current Transcript
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.CurrentTranscriptFileName))
                    {
                        <div class="d-flex align-items-start gap-3 mb-3 p-3"
                             style="background:var(--slate-50); border-radius:10px;">
                            <i class="bi bi-file-earmark-pdf-fill fs-3" style="color:var(--navy);" aria-hidden="true"></i>
                            <div>
                                <div style="font-weight:700; font-size:0.875rem; color:var(--navy);">
                                    @Model.CurrentTranscriptFileName
                                </div>
                                <div style="font-size:0.78rem; color:var(--slate-500);">
                                    Uploaded: @Model.CurrentTranscriptUploadDate
                                </div>
                                <div style="font-size:0.78rem; color:var(--slate-500);">
                                    Semester: @Model.CurrentTranscriptSemester
                                </div>
                            </div>
                        </div>

                        @if (Model.ShowApplyButton)
                        {
                            <div class="alert alert-info py-2 mb-3" style="font-size:0.82rem;">
                                <i class="bi bi-info-circle me-1" aria-hidden="true"></i>
                                Transcript is loaded and available to the AI Advisor. You can also apply
                                the GPA and credit totals from this transcript to your official record.
                            </div>

                            <form method="post" asp-page-handler="ApplyToRecord" class="mb-2">
                                <button type="submit" class="btn btn-outline-primary w-100"
                                        onclick="return confirm('Apply GPA and credits from this transcript to your record?')">
                                    <i class="bi bi-check2-circle me-2" aria-hidden="true"></i>Apply to My Record
                                </button>
                            </form>
                        }

                        <form method="post" asp-page-handler="RemoveTranscript">
                            <button type="submit" class="btn btn-outline-danger w-100"
                                    onclick="return confirm('Remove transcript from session?')">
                                <i class="bi bi-x-circle me-2" aria-hidden="true"></i>Remove from Session
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="text-center py-4" style="color:var(--slate-400);">
                            <i class="bi bi-file-earmark-x" style="font-size:2.5rem; display:block; margin-bottom:0.75rem;" aria-hidden="true"></i>
                            <p class="mb-0" style="font-size:0.875rem;">No transcript uploaded yet.</p>
                            <p style="font-size:0.8rem;">Upload your Degree Works PDF to get started.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Parsed Summary Preview -->
    @if (!string.IsNullOrEmpty(Model.ParseSummary))
    {
        <div class="card mt-4" style="border-radius:16px;">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span>
                    <i class="bi bi-eye me-2" aria-hidden="true"></i>What the AI Sees
                </span>
                <span class="badge" style="background:rgba(255,255,255,0.2); font-size:0.7rem;">
                    Parsed transcript context
                </span>
            </div>
            <div class="card-body p-0">
                <pre style="margin:0; padding:1.25rem; font-size:0.75rem; color:var(--slate-700);
                                background:var(--slate-50); border-radius:0 0 16px 16px;
                                max-height:400px; overflow-y:auto; white-space:pre-wrap; word-break:break-word;">@Model.ParseSummary</pre>
            </div>
        </div>
    }

    <!-- Info Card -->
    <div class="card mt-4" style="border-radius:16px;">
        <div class="card-body" style="padding:1.25rem 1.5rem;">
            <div class="section-header" style="margin-bottom:0.75rem; padding-bottom:0.75rem;">
                <h6>
                    <span class="section-icon"><i class="bi bi-lightbulb-fill" aria-hidden="true"></i></span>
                    What This Does
                </h6>
            </div>
            <div class="row g-2" style="font-size:0.875rem; color:var(--slate-700);">
                <div class="col-md-6">
                    <ul style="padding-left:1.25rem; display:flex; flex-direction:column; gap:0.4rem;">
                        <li>AI recognizes your transfer credits and where they applied</li>
                        <li>AI understands AP credits and what requirements they satisfied</li>
                        <li>AI sees your complete block-by-block completion status</li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <ul style="padding-left:1.25rem; display:flex; flex-direction:column; gap:0.4rem;">
                        <li>Especially helpful for new students or transfer students</li>
                        <li>Update every semester after grades are finalized</li>
                        <li>Your transcript is stored securely and only visible to you</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.getElementById('transcriptFile')?.addEventListener('change', function () {
            if (this.files[0] && this.files[0].size > 50 * 1024 * 1024) {
                alert('File exceeds 50MB limit. Please choose a smaller file.');
                this.value = '';
            }
        });

        document.querySelector('form[action*="Upload"]')?.addEventListener('submit', function () {
            var btn = document.getElementById('uploadBtn');
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>Parsing...';
            }
            window.showAiLoading?.();
        });
    </script>
}
