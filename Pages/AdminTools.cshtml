@page
@model AdminToolsModel
@{
    ViewData["Title"] = "Admin Tools";
}

<div class="container mt-4">
    <h2>Admin Tools</h2>
    <p class="text-muted">Administrative utilities for managing the system</p>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-cloud-download"></i> Sync Azure Files</h5>
                </div>
                <div class="card-body">
                    <p>Scan Azure blob storage and import file records into the database.</p>
                    <ul>
                        <li>Bulletins (majors)</li>
                        <li>Minors</li>
                        <li>Certificates</li>
                    </ul>
                    <a href="/SyncAzureFiles" class="btn btn-primary">
                        <i class="bi bi-arrow-repeat"></i> Sync Files
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-file-earmark-text"></i> Parse Bulletin Courses</h5>
                </div>
                <div class="card-body">
                    <p>Extract courses from all bulletins and populate the Courses table.</p>
                    <ul>
                        <li>Parses all bulletins</li>
                        <li>Extracts course codes, names, credits</li>
                        <li>Adds new courses to database</li>
                    </ul>
                    <a href="/ParseBulletinCourses" class="btn btn-success">
                        <i class="bi bi-lightning"></i> Parse Courses
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-bar-chart"></i> System Analytics</h5>
                </div>
                <div class="card-body">
                    <p>View comprehensive analytics and statistics</p>
                    <a href="/AdminAnalytics" class="btn btn-info">
                        <i class="bi bi-graph-up"></i> View Analytics
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>